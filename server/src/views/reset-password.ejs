<%- include('partials/header') %>

<div class="max-w-md mx-auto px-4 py-16">
  <div class="bg-white rounded-xl shadow-sm border p-8">
    <h1 class="text-2xl font-bold text-center mb-6"><%= t('auth.reset_password') %></h1>

    <div id="error-message" class="hidden bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm"></div>

    <form hx-post="/api/auth/reset-password" hx-target="this" hx-swap="outerHTML" class="space-y-4">
      <input type="hidden" name="token" value="<%= token %>">
      <div x-data="{ show: false }">
        <label class="block text-sm font-medium text-gray-700 mb-1"><%= t('auth.new_password') %></label>
        <div class="relative">
          <input :type="show ? 'text' : 'password'" name="password" required minlength="8" class="w-full px-3 py-2 pr-10 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
          <button type="button" @click="show = !show" class="absolute right-2 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 focus:outline-none">
            <svg x-show="!show" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
            <svg x-show="show" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
          </button>
        </div>
      </div>
      <div x-data="{ show: false }">
        <label class="block text-sm font-medium text-gray-700 mb-1"><%= t('auth.confirm_password') %></label>
        <div class="relative">
          <input :type="show ? 'text' : 'password'" name="confirmPassword" required minlength="8" class="w-full px-3 py-2 pr-10 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
          <button type="button" @click="show = !show" class="absolute right-2 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 focus:outline-none">
            <svg x-show="!show" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
            <svg x-show="show" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
          </button>
        </div>
      </div>
      <button type="submit" class="w-full bg-blue-600 text-white py-2.5 rounded-lg font-medium hover:bg-blue-700 transition">
        <%= t('auth.reset_password') %>
      </button>
    </form>
  </div>
</div>

<script>
  document.addEventListener('htmx:beforeRequest', function(evt) {
    if (evt.detail.elt?.getAttribute('hx-post') === '/api/auth/reset-password') {
      const pwd = evt.detail.elt.querySelector('input[name="password"]').value;
      const confirm = evt.detail.elt.querySelector('input[name="confirmPassword"]').value;
      if (pwd !== confirm) {
        evt.preventDefault();
        document.getElementById('error-message').textContent = '<%= t('auth.passwords_not_match').replace(/\\/g, '\\\\').replace(/'/g, "\\'") %>';
        document.getElementById('error-message').classList.remove('hidden');
      }
    }
  });
  document.addEventListener('htmx:afterRequest', function(evt) {
    if (evt.detail.successful && evt.detail.xhr.responseURL?.includes('/api/auth/reset-password')) {
      const resp = JSON.parse(evt.detail.xhr.response);
      if (resp.success) {
        window.location.href = '/login';
      } else if (resp.error) {
        const err = document.getElementById('error-message');
        err.textContent = resp.error;
        err.classList.remove('hidden');
      }
    }
  });
</script>

<%- include('partials/footer') %>
