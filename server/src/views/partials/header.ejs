<!DOCTYPE html>
<html lang="<%= locale %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= t('app.name') %> - <%= t('app.tagline') %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/htmx.org@1.9.10"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.13.5/dist/cdn.min.js"></script>
  <style>
    [x-cloak] { display: none !important; }
    .progress-bar { transition: width 0.3s ease; }
  </style>
</head>
<body class="bg-gray-50 min-h-screen flex flex-col">

  <!-- Top bar — shows for ALL users (logged in or not) -->
  <div class="bg-white border-b shadow-sm" x-data="{ mobileOpen: false }">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-14">
        <!-- Logo -->
        <a href="<%= user ? '/dashboard' : '/' %>" class="flex items-center gap-2 shrink-0">
          <span class="text-xl">📦</span>
          <span class="font-bold text-lg text-gray-900"><%= t('app.name') %></span>
        </a>

        <!-- Right side: language + user menu (desktop) -->
        <div class="flex items-center gap-3">
          <!-- Language Switcher (always visible) -->
          <div class="relative" x-data="{ langOpen: false }">
            <button @click="langOpen = !langOpen; if(typeof event!=='undefined')event.stopPropagation()" class="flex items-center gap-1 text-sm text-gray-600 hover:text-blue-600 px-2 py-1.5 rounded hover:bg-gray-100 border border-gray-200">
              <span><%= locale === 'zh' ? '🌐 中文' : '🌐 English' %></span>
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div x-show="langOpen" @click.away="langOpen = false" class="absolute right-0 mt-1 w-32 bg-white border rounded-lg shadow-lg z-50">
              <button onclick="switchLocale('zh')" class="block w-full text-left px-4 py-2.5 text-sm hover:bg-blue-50 rounded-t-lg <%= locale === 'zh' ? 'font-bold text-blue-600 bg-blue-50' : '' %>">🌐 中文</button>
              <button onclick="switchLocale('en')" class="block w-full text-left px-4 py-2.5 text-sm hover:bg-blue-50 rounded-b-lg <%= locale === 'en' ? 'font-bold text-blue-600 bg-blue-50' : '' %>">🌐 English</button>
            </div>
          </div>

          <% if (typeof user !== 'undefined' && user) { %>
            <!-- Logged-in user menu (desktop) -->
            <a href="/profile" class="hidden sm:inline text-sm text-gray-700 hover:text-blue-600 px-2 py-1.5 rounded hover:bg-gray-100">
              <%= user.email %>
            </a>
            <button onclick="logout()" class="hidden sm:inline text-sm text-red-600 hover:text-red-800 px-2 py-1.5 rounded hover:bg-red-50 border border-red-200">
              <%= t('nav.logout') %>
            </button>
          <% } else { %>
            <!-- Guest menu (desktop) — hidden on mobile, shown on md+ -->
            <div class="hidden md:flex items-center gap-2">
              <a href="/shares/redeem" class="text-sm text-green-700 hover:text-green-600 px-2 py-1.5 rounded hover:bg-green-50 border border-green-200">
                📥 <%= t('file.redeem_code') %>
              </a>
              <a href="/login" class="text-sm text-gray-700 hover:text-blue-600 px-3 py-1.5 rounded hover:bg-gray-100">
                <%= t('nav.login') %>
              </a>
              <a href="/register" class="text-sm bg-blue-600 text-white px-3 py-1.5 rounded-lg hover:bg-blue-700 transition">
                <%= t('nav.register') %>
              </a>
            </div>
          <% } %>

          <!-- Hamburger toggle (mobile only) -->
          <button @click="mobileOpen = !mobileOpen" class="md:hidden p-2 rounded-lg text-gray-600 hover:bg-gray-100 focus:outline-none" aria-label="Toggle menu">
            <svg x-show="!mobileOpen" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
            <svg x-show="mobileOpen" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile dropdown (shown when hamburger is open, md and below) -->
      <div x-show="mobileOpen" class="md:hidden pb-3 space-y-1" @click.away="mobileOpen = false">
        <% if (typeof user !== 'undefined' && user) { %>
          <a href="/files" class="block px-3 py-2 text-sm text-gray-700 hover:bg-blue-50 rounded"><%= t('nav.files') %></a>
          <a href="/files/upload" class="block px-3 py-2 text-sm text-gray-700 hover:bg-blue-50 rounded"><%= t('nav.upload') %></a>
          <a href="/shares" class="block px-3 py-2 text-sm text-gray-700 hover:bg-blue-50 rounded"><%= t('nav.share') %></a>
          <a href="/shares/redeem" class="block px-3 py-2 text-sm text-gray-700 hover:bg-blue-50 rounded"><%= t('share.download') %></a>
          <% if (user.role === 'admin') { %>
          <a href="/admin" class="block px-3 py-2 text-sm text-gray-700 hover:bg-blue-50 rounded"><%= t('nav.admin') %></a>
          <% } %>
          <hr class="my-2 border-gray-200">
          <a href="/profile" class="block px-3 py-2 text-sm text-gray-700 hover:bg-blue-50 rounded"><%= user.email %></a>
          <button onclick="logout()" class="block w-full text-left px-3 py-2 text-sm text-red-600 hover:bg-red-50 rounded"><%= t('nav.logout') %></button>
        <% } else { %>
          <a href="/shares/redeem" class="block px-3 py-2 text-sm text-green-700 hover:bg-green-50 rounded">📥 <%= t('file.redeem_code') %></a>
          <a href="/login" class="block px-3 py-2 text-sm text-gray-700 hover:bg-blue-50 rounded"><%= t('nav.login') %></a>
          <a href="/register" class="block px-3 py-2 text-sm text-blue-600 hover:bg-blue-50 rounded font-medium"><%= t('nav.register') %></a>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Desktop navigation bar — logged-in users only, md+ screens -->
  <% if (typeof user !== 'undefined' && user) { %>
  <nav class="hidden md:block bg-white border-b">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex h-10 items-center gap-1">
        <a href="/files" class="px-3 py-1.5 rounded-md text-sm font-medium text-gray-600 hover:text-blue-600 hover:bg-blue-50"><%= t('nav.files') %></a>
        <a href="/files/upload" class="px-3 py-1.5 rounded-md text-sm font-medium text-gray-600 hover:text-blue-600 hover:bg-blue-50"><%= t('nav.upload') %></a>
        <a href="/shares" class="px-3 py-1.5 rounded-md text-sm font-medium text-gray-600 hover:text-blue-600 hover:bg-blue-50"><%= t('nav.share') %></a>
        <a href="/shares/redeem" class="px-3 py-1.5 rounded-md text-sm font-medium text-gray-600 hover:text-blue-600 hover:bg-blue-50"><%= t('share.download') %></a>
        <% if (user.role === 'admin') { %>
        <a href="/admin" class="px-3 py-1.5 rounded-md text-sm font-medium text-gray-600 hover:text-blue-600 hover:bg-blue-50"><%= t('nav.admin') %></a>
        <% } %>
      </div>
    </div>
  </nav>
  <% } %>

  <main class="flex-1">
