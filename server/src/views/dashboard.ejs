<%- include('partials/header') %>

<div class="max-w-4xl mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold text-gray-900 mb-8"><%= t('app.dashboard') %></h1>

  <!-- Key Status Alert -->
  <% if (!hasKey) { %>
  <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-6 mb-8">
    <div class="flex items-start gap-4">
      <span class="text-2xl">⚠️</span>
      <div>
        <h3 class="font-bold text-yellow-800 mb-1"><%= t('key.key_required') %></h3>
        <p class="text-yellow-700 text-sm mb-3"><%= t('key.key_required_desc') %></p>
        <a href="/keys/generate" class="inline-block bg-yellow-500 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-yellow-600 transition">
          <%= t('key.generate') %>
        </a>
      </div>
    </div>
  </div>
  <% } else { %>
  <div class="bg-green-50 border border-green-200 rounded-xl p-6 mb-8">
    <div class="flex items-start gap-4">
      <span class="text-2xl">🔑</span>
      <div>
        <h3 class="font-bold text-green-800 mb-1"><%= t('key.key_ready') %></h3>
        <p class="text-green-700 text-sm"><%= t('key.key_ready_simple') %></p>
      </div>
    </div>
  </div>
  <% } %>

  <!-- Import Key Prompt (shown when public key exists but private key missing) -->
  <% if (hasKey) { %>
  <div id="import-prompt" class="hidden bg-orange-50 border border-orange-200 rounded-xl p-6 mb-8">
    <div class="flex items-start gap-4">
      <span class="text-2xl">🔄</span>
      <div>
        <h3 class="font-bold text-orange-800 mb-1"><%= t('key.import_prompt_title') %></h3>
        <p class="text-orange-700 text-sm mb-3"><%= t('key.import_prompt_desc') %></p>
        <a href="/keys/generate" class="inline-block bg-orange-500 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-orange-600 transition">
          📥 <%= t('key.import_action') %>
        </a>
      </div>
    </div>
  </div>
  <% } %>

  <!-- Quick Actions -->
  <div class="grid md:grid-cols-3 gap-6 mb-8">
    <a href="/files/upload" class="bg-white border rounded-xl p-6 hover:shadow-md transition text-center <%= !hasKey ? 'opacity-50 pointer-events-none' : '' %>">
      <div class="text-3xl mb-2">📤</div>
      <h3 class="font-semibold"><%= t('file.quick_upload') %></h3>
      <p class="text-sm text-gray-500 mt-1"><%= t('file.quick_upload_desc') %></p>
    </a>
    <a href="/shares" class="bg-white border rounded-xl p-6 hover:shadow-md transition text-center">
      <div class="text-3xl mb-2">🔗</div>
      <h3 class="font-semibold"><%= t('file.my_shares') %></h3>
      <p class="text-sm text-gray-500 mt-1"><%= t('file.my_shares_desc') %></p>
    </a>
    <a href="/shares/redeem" class="bg-white border rounded-xl p-6 hover:shadow-md transition text-center">
      <div class="text-3xl mb-2">📥</div>
      <h3 class="font-semibold"><%= t('file.redeem_code') %></h3>
      <p class="text-sm text-gray-500 mt-1"><%= t('file.redeem_code_desc') %></p>
    </a>
  </div>

  <!-- Recent Files -->
  <div class="bg-white border rounded-xl p-6">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-lg font-bold"><%= t('file.recent') %></h2>
      <a href="/files" class="text-sm text-blue-600 hover:underline"><%= t('nav.view_all') %></a>
    </div>
    <div id="recent-files" class="space-y-2">
      <div class="text-center py-8 text-gray-500" id="recent-loading"><%= t('common.loading') %></div>
    </div>
  </div>
</div>

<script>
  async function loadRecentFiles() {
    try {
      const res = await fetch('/api/files');
      const data = await res.json();
      const container = document.getElementById('recent-files');

      if (!data.files || data.files.length === 0) {
        container.innerHTML = '<div class="text-center py-8 text-gray-500 bg-gray-50 rounded-lg"><%= t("file.no_files") %></div>';
        return;
      }

      const recent = data.files.slice(0, 5);
      container.innerHTML = recent.map(f => `
        <a href="/files/${f.id}" class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-blue-50 transition">
          <div class="flex items-center gap-3">
            <span class="text-lg">📄</span>
            <div>
              <span class="font-medium text-sm">${escapeHtml(f.name)}</span>
              <p class="text-xs text-gray-500">${formatSize(f.size)}</p>
            </div>
          </div>
          <span class="text-xs text-gray-400">${new Date(f.createdAt).toLocaleDateString()}</span>
        </a>
      `).join('');
    } catch (err) {
      document.getElementById('recent-files').innerHTML = '<div class="text-center py-8 text-red-500 text-sm">Failed to load recent files</div>';
    }
  }

  function formatSize(bytes) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
    if (bytes < 1073741824) return (bytes / 1048576).toFixed(1) + ' MB';
    return (bytes / 1073741824).toFixed(2) + ' GB';
  }

  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  loadRecentFiles();

  // Check if private key exists in IndexedDB; if not, show import prompt
  <% if (hasKey) { %>
  (function checkPrivateKey() {
    try {
      const request = indexedDB.open('cista-keys', 1);
      request.onsuccess = (evt) => {
        const db = evt.target.result;
        const tx = db.transaction('keys', 'readonly');
        const store = tx.objectStore('keys');
        const getReq = store.get('private-key');
        getReq.onsuccess = () => {
          if (!getReq.result) {
            document.getElementById('import-prompt')?.classList.remove('hidden');
          }
        };
        getReq.onerror = () => {};
        tx.oncomplete = () => db.close();
      };
    } catch (e) {}
  })();
  <% } %>
</script>

<%- include('partials/footer') %>
