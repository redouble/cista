<%- include('partials/header') %>

<div class="max-w-2xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-8"><%= t('nav.profile') %></h1>

  <div class="space-y-6">
    <!-- Account Info -->
    <div class="bg-white rounded-xl shadow-sm border p-6">
      <h2 class="font-bold text-lg mb-4"><%= t('auth.account_info') %></h2>
      <div class="space-y-3 text-sm">
        <div class="flex justify-between py-2 border-b">
          <span class="text-gray-500"><%= t('auth.email') %></span>
          <span class="font-medium"><%= user.email %></span>
        </div>
        <div class="flex justify-between py-2 border-b">
          <span class="text-gray-500"><%= t('auth.role') %></span>
          <span class="font-medium capitalize"><%= user.role %></span>
        </div>
        <div class="flex justify-between py-2 border-b">
          <span class="text-gray-500"><%= t('auth.language') %></span>
          <span class="font-medium"><%= locale === 'zh' ? '中文' : 'English' %></span>
        </div>
      </div>
    </div>

    <!-- Key Info -->
    <div class="bg-white rounded-xl shadow-sm border p-6">
      <h2 class="font-bold text-lg mb-4">🔑 <%= t('key.encryption_key') %></h2>
      <% if (keyInfo) { %>
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-green-700 font-medium flex items-center gap-2">
            <span class="inline-block w-2 h-2 rounded-full bg-green-500"></span>
            <%= t('key.key_ready') %>
          </p>
          <p class="text-xs text-gray-500 mt-1"><%= t('key.browser_only_short') %></p>
        </div>
        <div x-data="{ showDetails: false }" class="relative">
          <button @click="showDetails = !showDetails" type="button" class="text-sm text-blue-600 hover:underline flex items-center gap-1">
            <span x-text="showDetails ? '<%= t('common.hide').replace(/\\/g, '\\\\\\\\').replace(/'/g, "\\'") %>' : '<%= t('common.details').replace(/\\/g, '\\\\\\\\').replace(/'/g, "\\'") %>'"></span>
          </button>
          <div x-show="showDetails" @click.away="showDetails = false" class="absolute mt-2 right-0 bg-white border rounded-lg shadow-lg p-4 z-10 w-80">
            <div class="space-y-2 text-sm">
              <div class="flex justify-between py-1 border-b">
                <span class="text-gray-500"><%= t('key.algorithm') %></span>
                <span class="font-medium"><%= keyInfo.algorithm %></span>
              </div>
              <div class="py-1 border-b">
                <span class="text-gray-500 block mb-1"><%= t('key.fingerprint') %></span>
                <code class="text-xs font-mono break-all"><%= keyInfo.fingerprint %></code>
                <button onclick="copyToClipboard('<%= keyInfo.fingerprint %>')" class="ml-2 text-xs text-blue-600 hover:underline"><%= t('common.copy') %></button>
              </div>
              <div class="pt-2 flex gap-3">
                <a href="/keys/generate" class="text-xs text-blue-600 hover:underline"><%= t('key.regenerate') %></a>
                <a href="/keys/upload" class="text-xs text-blue-600 hover:underline"><%= t('key.upload') %></a>
              </div>
            </div>
          </div>
        </div>
      </div>
      <% } else { %>
      <p class="text-gray-500 text-sm mb-3"><%= t('key.no_key') %></p>
      <div class="flex gap-3">
        <a href="/keys/generate" class="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition"><%= t('key.generate') %></a>
        <a href="/keys/upload" class="border px-4 py-2 rounded-lg text-sm hover:bg-gray-50"><%= t('key.upload') %></a>
      </div>
      <% } %>
    </div>

    <!-- Change Password -->
    <div class="bg-white rounded-xl shadow-sm border p-6">
      <h2 class="font-bold text-lg mb-4"><%= t('auth.change_password') %></h2>
      <div id="pwd-error" class="hidden bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm"></div>
      <form id="change-password-form" class="space-y-3">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1"><%= t('auth.current_password') %></label>
          <input type="password" name="currentPassword" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1"><%= t('auth.new_password') %></label>
          <input type="password" name="newPassword" required minlength="8" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
        </div>
        <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition">
          <%= t('auth.change_password') %>
        </button>
      </form>
    </div>

    <!-- Delete Account -->
    <div class="bg-white rounded-xl shadow-sm border p-6 border-red-200">
      <h2 class="font-bold text-lg text-red-700 mb-4">⚠️ <%= t('auth.delete_account') %></h2>
      <p class="text-sm text-gray-600 mb-4"><%= t('auth.delete_warning') %></p>
      <button onclick="deleteAccount()" class="bg-red-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-red-700 transition">
        <%= t('auth.delete_account') %>
      </button>
    </div>
  </div>
</div>

<script>
  document.getElementById('change-password-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const data = {
      currentPassword: form.currentPassword.value,
      newPassword: form.newPassword.value,
    };

    try {
      const res = await fetch('/api/auth/change-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const resp = await res.json();
      if (resp.success) {
        showSuccess('<%= t('auth.password_changed').replace(/\\/g, '\\\\').replace(/'/g, "\\'") %>');
        form.reset();
      } else {
        const err = document.getElementById('pwd-error');
        err.textContent = resp.error;
        err.classList.remove('hidden');
      }
    } catch (err) {
      showError('<%= t('common.failed').replace(/\\/g, '\\\\').replace(/'/g, "\\'") %>: ' + err.message);
    }
  });

  async function deleteAccount() {
    if (!confirm('<%= t('auth.delete_confirm').replace(/\\/g, '\\\\').replace(/'/g, "\\'") %>')) return;
    if (!confirm('<%= t('auth.delete_irreversible').replace(/\\/g, '\\\\').replace(/'/g, "\\'") %>')) return;

    const password = prompt('<%= t('auth.enter_password_confirm').replace(/\\/g, '\\\\').replace(/'/g, "\\'") %>');
    if (!password) return;

    try {
      const res = await fetch('/api/auth/account', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password }),
      });
      const data = await res.json();
      if (data.success) {
        window.location.href = '/';
      } else {
        showError(data.error);
      }
    } catch (err) {
      showError('<%= t('common.failed').replace(/\\/g, '\\\\').replace(/'/g, "\\'") %>: ' + err.message);
    }
  }

</script>

<%- include('partials/footer') %>
