<%- include('partials/header') %>

<div class="max-w-2xl mx-auto px-4 py-8" x-data="fileUploader()">
  <div class="bg-white rounded-xl shadow-sm border p-8">
    <h1 class="text-2xl font-bold text-center mb-6"><%= t('file.upload') %></h1>

    <!-- File Drop Zone -->
    <div @dragover.prevent="dragover = true" @dragleave="dragover = false" @drop.prevent="handleDrop($event)"
         :class="{'border-blue-500 bg-blue-50': dragover}"
         class="border-2 border-dashed border-gray-300 rounded-xl p-8 text-center cursor-pointer hover:border-blue-400 transition mb-6"
         @click="document.getElementById('file-input').click()">
      <div class="text-4xl mb-2">📁</div>
      <p class="text-gray-600" x-text="selectedFile ? selectedFile.name : '<%= t('file.drop').replace(/\\/g, '\\\\').replace(/'/g, "\\'") %>'"></p>
      <p class="text-sm text-gray-400 mt-1" x-text="selectedFile ? formatSize(selectedFile.size) : ''"></p>
      <input id="file-input" type="file" class="hidden" @change="selectedFile = $event.target.files[0]">
    </div>

    <!-- File Description -->
    <div class="mb-4">
      <label class="block text-sm font-medium text-gray-700 mb-1"><%= t('file.description') %></label>
      <input type="text" x-model="description" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" placeholder="<%= t('file.description_placeholder') %>">
    </div>

    <button @click="encryptAndUpload()" :disabled="!selectedFile || uploading"
            class="w-full bg-blue-600 text-white py-3 rounded-lg font-medium hover:bg-blue-700 transition disabled:opacity-50 disabled:cursor-not-allowed">
      <span x-show="!uploading && !encrypting"><%= t('file.upload') %></span>
      <span x-show="encrypting" x-text="'<%= t('file.encrypting').replace(/\\/g, '\\\\').replace(/'/g, "\\'") %> ' + encryptProgress + '%'"></span>
      <span x-show="uploading"><%= t('file.uploading') %></span>
    </button>

    <!-- Progress Bar -->
    <div x-show="encrypting || uploading" class="mt-4">
      <div class="w-full bg-gray-200 rounded-full h-3">
        <div class="bg-blue-600 h-3 rounded-full progress-bar" :style="'width: ' + totalProgress + '%'"></div>
      </div>
      <p class="text-sm text-gray-500 mt-1 text-center" x-text="statusText"></p>
    </div>

    <!-- Success -->
    <div x-show="success" class="mt-6 bg-green-50 border border-green-200 rounded-lg p-4 text-center">
      <p class="text-green-800 font-medium">✅ <%= t('file.upload_success') %></p>
      <div class="mt-3 flex justify-center gap-3">
        <a href="/files" class="text-blue-600 hover:underline text-sm"><%= t('nav.files') %></a>
        <a href="/files/upload" class="text-blue-600 hover:underline text-sm"><%= t('nav.upload_another') %></a>
      </div>
    </div>
  </div>
</div>

<script>
  function fileUploader() {
    return {
      selectedFile: null,
      description: '',
      encrypting: false,
      uploading: false,
      encryptProgress: 0,
      totalProgress: 0,
      statusText: '',
      success: false,
      dragover: false,

      handleDrop(event) {
        this.dragover = false;
        const file = event.dataTransfer.files[0];
        if (file) this.selectedFile = file;
      },

      async encryptAndUpload() {
        if (!this.selectedFile) return;
        this.encrypting = true;
        this.success = false;
        this.encryptProgress = 0;
        this.totalProgress = 0;
        this.statusText = '<%= t('file.reading').replace(/\\/g, '\\\\').replace(/'/g, "\\'") %>';

        try {
          // Step 1: Read the file
          const fileData = await this.readFile(this.selectedFile);
          this.encryptProgress = 10;
          this.totalProgress = 10;

          // Step 2: Get own public key to encrypt the DEK
          // (the DEK is encrypted with the owner's key; share codes
          //  re-encrypt it per recipient via the share code flow)
          this.statusText = '<%= t('file.getting_key').replace(/\\/g, '\\\\').replace(/'/g, "\\'") %>';
          let ownerPublicKeyPem = null;
          let ownerAlgorithm = 'rsa-4096';

          const myKeyRes = await fetch('/api/keys/mine');
          const myKey = await myKeyRes.json();
          if (myKey.publicKey) {
            ownerPublicKeyPem = myKey.publicKey;
            ownerAlgorithm = myKey.algorithm;
          }

          if (!ownerPublicKeyPem) {
            showError('<%= t('file.no_public_key').replace(/\\/g, '\\\\').replace(/'/g, "\\'") %>');
            this.encrypting = false;
            return;
          }
          this.encryptProgress = 20;
          this.totalProgress = 20;

          // Step 3: Generate a random DEK (Data Encryption Key)
          this.statusText = '<%= t('file.generating_dek').replace(/\\/g, '\\\\').replace(/'/g, "\\'") %>';
          const dek = await crypto.subtle.generateKey(
            { name: 'AES-GCM', length: 256 },
            true,
            ['encrypt', 'decrypt']
          );
          this.encryptProgress = 30;
          this.totalProgress = 30;

          // Step 4: Encrypt the file data with DEK
          this.statusText = '<%= t('file.encrypting_file').replace(/\\/g, '\\\\').replace(/'/g, "\\'") %>';
          const iv = crypto.getRandomValues(new Uint8Array(12));
          const encryptedFile = await crypto.subtle.encrypt(
            { name: 'AES-GCM', iv },
            dek,
            fileData
          );
          this.encryptProgress = 60;
          this.totalProgress = 50;

          // Step 5: Encrypt the DEK with the owner's public key
          this.statusText = '<%= t('file.encrypting_key').replace(/\\/g, '\\\\').replace(/'/g, "\\'") %>';
          const publicKey = await this.importPublicKey(ownerPublicKeyPem, ownerAlgorithm);
          const dekRaw = await crypto.subtle.exportKey('raw', dek);

          let encryptedDek;
          if (ownerAlgorithm === 'rsa-4096' || ownerAlgorithm === 'ecc-x25519') {
            encryptedDek = await crypto.subtle.encrypt(
              { name: 'RSA-OAEP' },
              publicKey,
              dekRaw
            );
          } else {
            throw new Error('Unsupported key algorithm: ' + ownerAlgorithm);
          }
          this.encryptProgress = 80;
          this.totalProgress = 65;

          // Step 6: Prepare upload
          this.statusText = '<%= t('file.encrypt_complete').replace(/\\/g, '\\\\').replace(/'/g, "\\'") %>';
          this.encrypting = false;
          this.uploading = true;
          this.totalProgress = 70;

          // Combine IV + encrypted data
          const combined = new Uint8Array(iv.length + new Uint8Array(encryptedFile).length);
          combined.set(iv);
          combined.set(new Uint8Array(encryptedFile), iv.length);

          const formData = new FormData();
          formData.append('file', new Blob([combined], { type: 'application/octet-stream' }), this.selectedFile.name);
          formData.append('encryptedKey', arrayBufferToBase64(encryptedDek));
          formData.append('encryptedKeyAlgorithm', ownerAlgorithm);
          formData.append('description', this.description);
          formData.append('fileName', this.selectedFile.name);

          // Step 7: Upload
          this.statusText = '<%= t('file.uploading').replace(/\\/g, '\\\\').replace(/'/g, "\\'") %>';
          const xhr = new XMLHttpRequest();
          xhr.withCredentials = true;
          xhr.upload.onprogress = (e) => {
            if (e.lengthComputable) {
              const uploadProgress = (e.loaded / e.total) * 30;
              this.totalProgress = 70 + uploadProgress;
              this.statusText = '<%= t('file.uploading').replace(/\\/g, '\\\\').replace(/'/g, "\\'") %> ' + Math.round(uploadProgress) + '%';
            }
          };

          await new Promise((resolve, reject) => {
            xhr.onload = () => {
              if (xhr.status === 200) resolve();
              else reject(new Error('Upload failed: ' + xhr.status));
            };
            xhr.onerror = reject;
            xhr.open('POST', '/api/files/upload');
            xhr.send(formData);
          });

          this.totalProgress = 100;
          this.statusText = '<%= t('file.upload_success').replace(/\\/g, '\\\\').replace(/'/g, "\\'") %>';
          this.success = true;
        } catch (err) {
          console.error('Encrypt/upload failed:', err);
          showError('<%= t('common.failed').replace(/\\/g, '\\\\').replace(/'/g, "\\'") %>: ' + err.message);
        } finally {
          this.encrypting = false;
          this.uploading = false;
        }
      },

      async importPublicKey(pem, algorithm) {
        // Clean the PEM string: trim whitespace, normalize line endings
        const cleaned = pem.trim();
        const pemHeader = '-----BEGIN PUBLIC KEY-----';
        const pemFooter = '-----END PUBLIC KEY-----';
        const startIdx = cleaned.indexOf(pemHeader);
        const endIdx = cleaned.indexOf(pemFooter);
        if (startIdx === -1 || endIdx === -1) {
          throw new Error('Invalid PEM format: missing header or footer');
        }
        const pemContents = cleaned.substring(startIdx + pemHeader.length, endIdx)
          .replace(/\r?\n/g, '').replace(/\r/g, '').trim();
        const binaryDer = Uint8Array.from(atob(pemContents), c => c.charCodeAt(0));

        const isRsa = algorithm === 'rsa-4096' || algorithm === 'ecc-x25519';
        return await crypto.subtle.importKey(
          'spki',
          binaryDer,
          isRsa
            ? { name: 'RSA-OAEP', hash: 'SHA-256' }
            : { name: 'ECDH', namedCurve: 'P-256' },
          false,
          isRsa ? ['encrypt'] : ['deriveBits', 'deriveKey']
        );
      },

      readFile(file) {
        return new Promise((resolve, reject) => {
          const reader = new FileReader();
          reader.onload = () => resolve(reader.result);
          reader.onerror = reject;
          reader.readAsArrayBuffer(file);
        });
      },

      formatSize(bytes) {
        if (bytes < 1024) return bytes + ' B';
        if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
        if (bytes < 1073741824) return (bytes / 1048576).toFixed(1) + ' MB';
        return (bytes / 1073741824).toFixed(2) + ' GB';
      }
    }
  }

  function arrayBufferToBase64(buffer) {
    const bytes = new Uint8Array(buffer);
    let binary = '';
    for (let i = 0; i < bytes.length; i++) {
      binary += String.fromCharCode(bytes[i]);
    }
    return btoa(binary);
  }
</script>

<%- include('partials/footer') %>
