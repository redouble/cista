<%- include('partials/header') %>

<div class="max-w-2xl mx-auto px-4 py-8">
  <div class="bg-white rounded-xl shadow-sm border p-8">
    <h1 class="text-2xl font-bold text-center mb-4"><%= t('key.upload_title') %></h1>
    <p class="text-gray-600 text-center mb-8"><%= t('key.upload_desc') %></p>

    <div id="error-message" class="hidden bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm"></div>

    <form id="key-upload-form" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2"><%= t('key.algorithm') %></label>
        <select name="algorithm" class="w-full px-3 py-2 border border-gray-300 rounded-lg">
          <option value="rsa-4096">RSA-4096</option>
          <option value="ecc-x25519">RSA-2048</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2"><%= t('key.public_key_pem') %></label>
        <textarea name="publicKey" rows="8" class="w-full px-3 py-2 border border-gray-300 rounded-lg font-mono text-sm focus:ring-2 focus:ring-blue-500 outline-none" placeholder="-----BEGIN PUBLIC KEY-----&#10;...&#10;-----END PUBLIC KEY-----"></textarea>
      </div>
      <button type="submit" class="w-full bg-blue-600 text-white py-2.5 rounded-lg font-medium hover:bg-blue-700 transition">
        <%= t('key.upload') %>
      </button>
    </form>

    <div id="result" class="hidden mt-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <p class="text-green-800 font-medium">✅ <%= t('key.upload') %><%= t('common.success') %>!</p>
        <p class="text-sm text-green-700 mt-1"><%= t('key.fingerprint') %>: <code id="fingerprint" class="bg-green-100 px-1 rounded"></code></p>
      </div>
      <div class="text-center mt-4">
        <a href="/dashboard" class="text-blue-600 hover:underline text-sm">Continue to Dashboard →</a>
      </div>
    </div>
  </div>
</div>

<script>
  document.getElementById('key-upload-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const data = { publicKey: form.publicKey.value, algorithm: form.algorithm.value };

    try {
      const res = await fetch('/api/keys/upload', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const resp = await res.json();
      if (resp.success) {
        document.getElementById('fingerprint').textContent = resp.fingerprint;
        document.getElementById('result').classList.remove('hidden');
        form.style.display = 'none';
      } else {
        const err = document.getElementById('error-message');
        err.textContent = resp.error;
        err.classList.remove('hidden');
      }
    } catch (err) {
      showError('Upload failed: ' + err.message);
    }
  });
</script>

<%- include('partials/footer') %>
