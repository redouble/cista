<%- include('partials/header') %>

<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="mb-6">
    <a href="/files" class="text-blue-600 hover:underline text-sm">← <%= t('common.back') %></a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border p-6 mb-6">
    <div class="flex items-start gap-4 mb-6">
      <span class="text-3xl">📄</span>
      <div>
        <h1 class="text-2xl font-bold"><%= file.name %></h1>
        <p class="text-gray-500 text-sm mt-1">
          <%= file.size %> bytes · <%= new Date(file.created_at).toLocaleString() %>
          <% if (file.description) { %> · <%= file.description %><% } %>
        </p>
      </div>
    </div>

    <div class="flex gap-3">
      <button onclick="downloadFile()" class="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition">
        📥 Download
      </button>
      <button onclick="generateShareCode()" class="bg-green-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-green-700 transition">
        🔗 <%= t('share.generate') %>
      </button>
    </div>
  </div>

  <!-- Share Codes -->
  <div class="bg-white rounded-xl shadow-sm border p-6">
    <h2 class="text-lg font-bold mb-4"><%= t('nav.share') %></h2>

    <% if (shareCodes.length === 0) { %>
    <p class="text-gray-500 text-sm"><%= t('share.no_codes') %></p>
    <% } else { %>
    <div class="space-y-3">
      <% shareCodes.forEach(function(sc) { %>
      <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
        <div>
          <code class="font-mono font-bold text-lg"><%= sc.code %></code>
          <p class="text-xs text-gray-500">
          <p class="text-xs text-gray-500">
            <%= sc.share_type === 'registered' ? t('share.registered') : t('share.unregistered') %> ·
            <%= sc.download_count %>/<%= sc.max_downloads %> <%= t('share.downloads_count') %>
            <% if (sc.expires_at) { %> · <%= t('share.expires') %>: <%= new Date(sc.expires_at).toLocaleDateString() %><% } %>
          </p>
        </div>
        <div class="flex gap-2">
          <button onclick="copyToClipboard('<%= sc.code %>')" class="text-blue-600 text-sm hover:underline"><%= t('common.copy') %></button>
          <% if (sc.is_active) { %>
          <button onclick="revokeShare('<%= sc.id %>')" class="text-red-600 text-sm hover:underline"><%= t('share.revoke') %></button>
          <% } else { %>
          <button onclick="revokeShare('<%= sc.id %>')" class="text-red-600 text-sm hover:underline"><%= t('share.revoke') %></button>
          <% } else { %>
          <span class="text-gray-400 text-sm">Revoked</span>
          <% } %>
        </div>
      </div>
      <% }); %>
    </div>
    <% } %>
  </div>
</div>

<!-- Share Code Generation Modal -->
<div id="share-modal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50" x-data="shareModal()">
  <div class="bg-white rounded-xl p-6 max-w-md w-full mx-4 shadow-xl">
    <h3 class="text-lg font-bold mb-4"><%= t('share.generate') %></h3>

    <div class="mb-4">
      <label class="block text-sm font-medium text-gray-700 mb-2"><%= t('share.type') %></label>
      <select id="share-type" class="w-full px-3 py-2 border rounded-lg" @change="onTypeChange()">
        <option value="registered"><%= t('share.registered') %></option>
        <option value="unregistered"><%= t('share.unregistered') %></option>
      </select>
    </div>

    <div id="unregistered-warning" class="hidden bg-yellow-50 border border-yellow-200 rounded-lg p-3 mb-4 text-sm text-yellow-700">
      ⚠️ <%= t('share.unregistered_warning') %>
    </div>

    <div class="mb-4">
      <label class="block text-sm font-medium text-gray-700 mb-2"><%= t('file.recipient') %> Email</label>
      <input type="email" id="target-email" class="w-full px-3 py-2 border rounded-lg" placeholder="recipient@example.com">
    </div>

    <div class="flex gap-4 mb-4">
      <div class="flex-1">
        <label class="block text-xs font-medium text-gray-700 mb-1"><%= t('share.expires') %></label>
        <select id="share-expiry" class="w-full px-2 py-2 border rounded-lg text-sm">
          <option value="1">1 day</option>
          <option value="7" selected>7 days</option>
          <option value="30">30 days</option>
          <option value="">Never</option>
        </select>
      </div>
      <div class="flex-1">
        <label class="block text-xs font-medium text-gray-700 mb-1"><%= t('share.max_downloads') %></label>
        <select id="share-max-downloads" class="w-full px-2 py-2 border rounded-lg text-sm">
          <option value="1">1 time</option>
          <option value="5" selected>5 times</option>
          <option value="10">10 times</option>
          <option value="0">Unlimited</option>
        </select>
      </div>
    </div>

    <div class="flex gap-3">
      <button onclick="closeModal()" class="flex-1 px-4 py-2 border rounded-lg text-sm hover:bg-gray-50"><%= t('common.cancel') %></button>
      <button id="generate-btn" onclick="doGenerateShare()" class="flex-1 bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition">
        <%= t('share.generate') %>
      </button>
    </div>

    <div id="share-result" class="hidden mt-4 p-3 bg-green-50 border border-green-200 rounded-lg text-center">
      <p class="text-green-800 font-medium">Share Code Generated!</p>
      <code id="generated-code" class="text-2xl font-mono font-bold block mt-2"></code>
      <button onclick="copyToClipboard(document.getElementById('generated-code').textContent)" class="text-blue-600 text-sm mt-2 hover:underline">Copy Code</button>
    </div>
  </div>
</div>

<script>
  function shareModal() {
    return {
      onTypeChange() {
        const type = document.getElementById('share-type').value;
        document.getElementById('unregistered-warning').classList.toggle('hidden', type !== 'unregistered');
      }
    }
  }

  function generateShareCode() {
    document.getElementById('share-modal').classList.remove('hidden');
    document.getElementById('share-modal').classList.add('flex');
  }

  function closeModal() {
    document.getElementById('share-modal').classList.add('hidden');
    document.getElementById('share-modal').classList.remove('flex');
    document.getElementById('share-result').classList.add('hidden');
  }

  async function doGenerateShare() {
    const type = document.getElementById('share-type').value;
    const email = document.getElementById('target-email').value;
    const expiry = document.getElementById('share-expiry').value;
    const maxDownloads = document.getElementById('share-max-downloads').value;

    try {
      document.getElementById('generate-btn').disabled = true;

      // Step 1: Fetch file info to get the encrypted DEK
      const fileRes = await fetch('/api/files/<%= file.id %>');
      const fileData = await fileRes.json();
      if (!fileData.file) { showError('File not found'); return; }

      const storedEncryptedKey = fileData.file.encryptedKey;
      // encryptedKey comes as base64 from the server
      const encryptedKeyBuffer = typeof storedEncryptedKey === 'string'
        ? base64ToArrayBuffer(storedEncryptedKey)
        : base64ToArrayBuffer(storedEncryptedKey);

      // Step 2: Decrypt the DEK with the owner's private key
      const privateKey = await getPrivateKey();
      if (!privateKey) { showError('<%= t('key.import_prompt_download').replace(/\\/g, '\\\\').replace(/'/g, "\\'") %>'); return; }

      const dek = await crypto.subtle.decrypt(
        { name: 'RSA-OAEP' },
        privateKey,
        encryptedKeyBuffer
      );

      // Step 3: Re-encrypt the DEK for the share recipient
      let newEncryptedDek;
      let tempPrivateKeyEncrypted = '';

      if (type === 'registered') {
        // Re-encrypt DEK with recipient's public key
        const keyRes = await fetch('/api/keys/by-email/' + encodeURIComponent(email));
        const keyData = await keyRes.json();
        if (!keyData.found) { showError('Recipient has not uploaded a public key'); return; }

        const publicKey = await importPublicKey(keyData.publicKey, keyData.algorithm);
        newEncryptedDek = await crypto.subtle.encrypt({ name: 'RSA-OAEP' }, publicKey, dek);
      } else {
        // Unregistered share: generate temp key pair
        const tempKeyPair = await crypto.subtle.generateKey(
          { name: 'RSA-OAEP', modulusLength: 2048, publicExponent: new Uint8Array([1, 0, 1]), hash: 'SHA-256' },
          true,
          ['encrypt', 'decrypt']
        );

        // Encrypt DEK with temp public key
        newEncryptedDek = await crypto.subtle.encrypt({ name: 'RSA-OAEP' }, tempKeyPair.publicKey, dek);

        // Export and encrypt temp private key with a key derived from the share code
        const tempPrivateKeyRaw = await crypto.subtle.exportKey('pkcs8', tempKeyPair.privateKey);
        tempPrivateKeyEncrypted = arrayBufferToBase64(tempPrivateKeyRaw);
      }

      // Step 4: Generate the share code
      const res = await fetch('/api/shares/generate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          fileId: '<%= file.id %>',
          shareType: type,
          targetEmail: email || undefined,
          encryptedDek: arrayBufferToBase64(newEncryptedDek),
          tempPrivateKeyEncrypted: tempPrivateKeyEncrypted || undefined,
          expiresAt: expiry ? new Date(Date.now() + parseInt(expiry) * 86400000).toISOString() : undefined,
          maxDownloads: parseInt(maxDownloads) || undefined,
        }),
      });

      const resp = await res.json();
      if (resp.success) {
        document.getElementById('generated-code').textContent = resp.code;
        document.getElementById('share-result').classList.remove('hidden');
        setTimeout(() => location.reload(), 2000);
      } else {
        showError(resp.error);
        document.getElementById('generate-btn').disabled = false;
      }
    } catch (err) {
      showError('Failed to generate share code: ' + err.message);
      document.getElementById('generate-btn').disabled = false;
    }
  }

  async function importPublicKey(pem, algorithm) {
    const pemHeader = '-----BEGIN PUBLIC KEY-----';
    const pemFooter = '-----END PUBLIC KEY-----';
    const cleaned = pem.trim();
    const startIdx = cleaned.indexOf(pemHeader);
    const endIdx = cleaned.indexOf(pemFooter);
    const pemContents = cleaned.substring(startIdx + pemHeader.length, endIdx)
      .replace(/\r?\n/g, '').replace(/\r/g, '').trim();
    const binaryDer = Uint8Array.from(atob(pemContents), c => c.charCodeAt(0));
    const isRsa = algorithm === 'rsa-4096' || algorithm === 'ecc-x25519';
    return await crypto.subtle.importKey(
      'spki', binaryDer,
      isRsa ? { name: 'RSA-OAEP', hash: 'SHA-256' } : { name: 'ECDH', namedCurve: 'P-256' },
      false, ['encrypt']
    );
  }

  async function revokeShare(id) {
    if (!confirm('<%= t('share.revoke_confirm').replace(/\\/g, '\\\\').replace(/'/g, "\\'") %>')) return;
    try {
      const res = await fetch('/api/shares/' + id, { method: 'DELETE' });
      const data = await res.json();
      if (data.success) location.reload();
      else { if (data.error) showError(data.error); }
    } catch (err) {
      showError('Failed to revoke share code');
    }
  }

  async function downloadFile() {
    try {
      const res = await fetch('/api/files/download/<%= file.id %>');
      const data = await res.json();
      if (!data.file) { showError('Download failed'); return; }

      // Decrypt in browser
      const encryptedData = base64ToArrayBuffer(data.file.encryptedData);
      const encryptedKey = base64ToArrayBuffer(data.file.encryptedKey);

      // Get private key from IndexedDB
      const privateKey = await getPrivateKey();
      if (!privateKey) { showError('<%= t('key.import_prompt_download').replace(/\\/g, '\\\\').replace(/'/g, "\\'") %>'); return; }

      // Decrypt the DEK
      const dek = await crypto.subtle.decrypt(
        { name: 'RSA-OAEP' },
        privateKey,
        encryptedKey
      );

      // Import the DEK
      const aesKey = await crypto.subtle.importKey('raw', dek, { name: 'AES-GCM', length: 256 }, false, ['decrypt']);

      // Extract IV (first 12 bytes) and ciphertext
      const iv = new Uint8Array(encryptedData.slice(0, 12));
      const ciphertext = encryptedData.slice(12);

      // Decrypt
      const decrypted = await crypto.subtle.decrypt({ name: 'AES-GCM', iv }, aesKey, ciphertext);

      // Save file
      const blob = new Blob([decrypted], { type: data.file.mimeType || 'application/octet-stream' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = data.file.name;
      a.click();
      URL.revokeObjectURL(url);
    } catch (err) {
      console.error('Download/decrypt failed:', err);
      showError('Download failed: ' + err.message);
    }
  }

  function base64ToArrayBuffer(base64) {
    const binary = atob(base64);
    const bytes = new Uint8Array(binary.length);
    for (let i = 0; i < binary.length; i++) {
      bytes[i] = binary.charCodeAt(i);
    }
    return bytes.buffer;
  }

  function arrayBufferToBase64(buffer) {
    const bytes = new Uint8Array(buffer);
    let binary = '';
    for (let i = 0; i < bytes.length; i++) {
      binary += String.fromCharCode(bytes[i]);
    }
    return btoa(binary);
  }

  async function getPrivateKey() {
    return new Promise((resolve, reject) => {
      const request = indexedDB.open('cista-keys', 1);
      request.onsuccess = (evt) => {
        const db = evt.target.result;
        const tx = db.transaction('keys', 'readonly');
        const store = tx.objectStore('keys');
        const getReq = store.get('private-key');
        getReq.onsuccess = async () => {
          if (!getReq.result) { resolve(null); return; }

          const stored = getReq.result;
          const encryptedData = new Uint8Array(stored.encryptedData);

          // Extract salt (16), iv (12), and ciphertext
          const salt = encryptedData.slice(0, 16);
          const iv = encryptedData.slice(16, 28);
          const ciphertext = encryptedData.slice(28);

          try {
            const password = prompt('Enter your password to decrypt your private key:');
            if (!password) { resolve(null); return; }

            const pbkdfKey = await crypto.subtle.importKey('raw', new TextEncoder().encode(password), 'PBKDF2', false, ['deriveKey']);
            const aesKey = await crypto.subtle.deriveKey(
              { name: 'PBKDF2', salt, iterations: 600000, hash: 'SHA-256' },
              pbkdfKey,
              { name: 'AES-GCM', length: 256 },
              false,
              ['decrypt']
            );

            const decrypted = await crypto.subtle.decrypt({ name: 'AES-GCM', iv }, aesKey, ciphertext);

            const privateKey = await crypto.subtle.importKey(
              'pkcs8',
              decrypted,
              { name: 'RSA-OAEP', hash: 'SHA-256' },
              false,
              ['decrypt']
            );

            resolve(privateKey);
          } catch (err) {
            showError('Failed to decrypt private key. Wrong password?');
            resolve(null);
          }
        };
        getReq.onerror = reject;
      };
      request.onerror = reject;
    });
  }
</script>

<%- include('partials/footer') %>
