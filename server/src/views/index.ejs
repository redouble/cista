<%- include('partials/header') %>

<!-- Hero Section -->
<div class="max-w-4xl mx-auto px-4 py-16 text-center">
  <div class="text-6xl mb-6">📦</div>
  <h1 class="text-5xl font-bold text-gray-900 mb-4"><%= t('app.name') %></h1>
  <p class="text-xl text-gray-600 mb-8"><%= t('app.tagline') %></p>

  <div class="flex justify-center gap-4 mb-16">
    <a href="/register" class="bg-blue-600 text-white px-8 py-3 rounded-lg font-medium hover:bg-blue-700 transition shadow-lg">
      <%= t('auth.register') %>
    </a>
    <a href="/login" class="bg-white text-blue-600 border-2 border-blue-600 px-8 py-3 rounded-lg font-medium hover:bg-blue-50 transition">
      <%= t('auth.login') %>
    </a>
  </div>

  <!-- Redeem Section for guests -->
  <div class="mt-8 mb-16 pt-8 border-t border-gray-200">
    <p class="text-gray-500 text-sm mb-4"><%= t('file.redeem_code_desc') %></p>
    <a href="/shares/redeem" class="inline-block bg-green-600 text-white px-6 py-2.5 rounded-lg font-medium hover:bg-green-700 transition shadow">
      📥 <%= t('file.redeem_code') %>
    </a>
  </div>

  <!-- Features -->
  <div class="grid md:grid-cols-3 gap-8 text-left mt-20">
    <div class="bg-white p-6 rounded-xl shadow-sm border">
      <div class="text-3xl mb-3">🔑</div>
      <h3 class="font-bold text-lg mb-2"><%= t('app.feature_key_title') %></h3>
      <p class="text-gray-600 text-sm"><%= t('app.feature_key_desc') %></p>
    </div>
    <div class="bg-white p-6 rounded-xl shadow-sm border">
      <div class="text-3xl mb-3">🔒</div>
      <h3 class="font-bold text-lg mb-2"><%= t('app.feature_e2ee_title') %></h3>
      <p class="text-gray-600 text-sm"><%= t('app.feature_e2ee_desc') %></p>
    </div>
    <div class="bg-white p-6 rounded-xl shadow-sm border">
      <div class="text-3xl mb-3">📤</div>
      <h3 class="font-bold text-lg mb-2"><%= t('app.feature_share_title') %></h3>
      <p class="text-gray-600 text-sm"><%= t('app.feature_share_desc') %></p>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
