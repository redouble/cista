<%- include('partials/header') %>

<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900"><%= t('nav.share') %></h1>
    <a href="/shares/redeem" class="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition">
      📥 <%= t('share.download') %>
    </a>
  </div>

  <div id="share-list" class="space-y-3">
    <div class="text-center py-12 text-gray-500"><%= t('common.loading') %></div>
  </div>
</div>

<script>
  async function loadShares() {
    try {
      const res = await fetch('/api/shares/mine');
      const data = await res.json();
      const container = document.getElementById('share-list');

      if (!data.codes || data.codes.length === 0) {
        container.innerHTML = '<div class="text-center py-12 text-gray-500 bg-white border rounded-xl"><div class="text-4xl mb-3">🔗</div><p><%= t("share.no_codes") %></p></div>';
        return;
      }

      container.innerHTML = data.codes.map(c => `
        <div class="bg-white border rounded-xl p-4 flex items-center justify-between hover:shadow-sm transition">
          <div>
            <code class="font-mono font-bold text-lg ${c.isActive ? 'text-green-700' : 'text-gray-400'}">${c.code}</code>
            <p class="text-xs text-gray-500">
              ${c.fileName || '<%= t('share.unknown_file') %>'} ·
              ${c.shareType === 'registered' ? '<%= t("share.registered") %>' : '<%= t("share.unregistered") %>'} ·
              ${c.downloadCount}/${c.maxDownloads} <%= t('share.downloads_count') %>
              ${c.expiresAt ? ' · <%= t('share.expires') %>: ' + new Date(c.expiresAt).toLocaleDateString() : ''}
            </p>
          </div>
          <div class="flex gap-2">
            <button onclick="copyToClipboard('${c.code}')" class="text-blue-600 text-sm hover:underline"><%= t('common.copy') %></button>
            ${c.isActive ? `<button onclick="revokeShare('${c.id}')" class="text-red-600 text-sm hover:underline"><%= t("share.revoke") %></button>` : '<span class="text-gray-400 text-sm"><%= t('share.revoked') %></span>'}
          </div>
        </div>
      `).join('');
    } catch (err) {
      document.getElementById('share-list').innerHTML = '<div class="text-center py-12 text-red-500"><%= t("common.failed") %></div>';
    }
  }

  async function revokeShare(id) {
    if (!confirm('<%= t("share.revoke_confirm") %>')) return;
    try {
      const res = await fetch('/api/shares/' + id, { method: 'DELETE' });
      const data = await res.json();
      if (data.success) loadShares();
      else showError(data.error);
    } catch (err) {
      showError('<%= t('share.revoke_failed').replace(/\\/g, '\\\\').replace(/'/g, "\\'") %>');
    }
  }

  loadShares();
</script>

<%- include('partials/footer') %>
